{
  "$schema": "Template config for Morpheus Agent. Copy relevant sections into your openclaw.json.",
  "_instructions": [
    "This template configures Morpheus P2P inference for your OpenClaw agent.",
    "Default stack: Morpheus P2P + local Ollama fallback.",
    "No centralized API keys in default config.",
    "Valid model prefixes: 'morpheus/' (local P2P) or 'mor-gateway/' (API Gateway).",
    "Hardware-adaptive Gemma 4 selection runs automatically during setup."
  ],
  "morpheus": {
    "_comment": "Morpheus P2P inference requires staked MOR tokens or bootstrap key.",
    "stakeCheck": true
  },
  "openclaw": {
    "controlUi": {
      "_comment": "Required when OpenClaw binds to non-loopback (0.0.0.0 / lan).",
      "enabled": true,
      "dangerouslyDisableDeviceAuth": true,
      "allowInsecureAuth": true,
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789",
        "http://[::1]:18789"
      ],
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "mor-gateway": {
        "_comment": "Morpheus API Gateway — requires MOR stake or bootstrap key from app.mor.org",
        "baseUrl": "https://api.mor.org/api/v1",
        "apiKey": "YOUR_MOR_GATEWAY_API_KEY",
        "api": "openai-completions",
        "models": [
          {
            "id": "glm-5",
            "name": "GLM-5 (via Morpheus Gateway)",
            "reasoning": false,
            "input": ["text"],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 131072,
            "maxTokens": 8192
          },
          {
            "id": "glm-4.7-flash",
            "name": "GLM 4.7 Flash (via Morpheus Gateway)",
            "reasoning": false,
            "input": ["text"],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 131072,
            "maxTokens": 8192
          }
        ]
      },
      "ollama": {
        "_comment": "Local Ollama fallback — hardware-adaptive Gemma 4 selection. Run 'bash scripts/setup-ollama.sh --apply' to auto-detect optimal model.",
        "baseUrl": "http://127.0.0.1:11434/v1",
        "api": "ollama",
        "models": [
          {
            "id": "gemma4:e4b",
            "name": "Gemma 4 E4B (Local Ollama)",
            "reasoning": false,
            "input": ["text", "image", "audio"],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 131072,
            "maxTokens": 16384
          }
        ]
      },
      "morpheus": {
        "_comment": "Morpheus P2P — requires staked MOR tokens",
        "baseUrl": "http://127.0.0.1:8083/v1",
        "apiKey": "morpheus-local",
        "api": "openai-completions",
        "models": [
          {
            "id": "glm-5",
            "name": "GLM-5 (via Morpheus P2P)",
            "reasoning": false,
            "input": ["text"],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 131072,
            "maxTokens": 8192
          },
          {
            "id": "glm-4.7-flash",
            "name": "GLM 4.7 Flash (via Morpheus P2P)",
            "reasoning": false,
            "input": ["text"],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 131072,
            "maxTokens": 8192
          }
        ]
      }
    },
    "router": {
      "_comment": "Model tier routing — HEAVY=GLM-5, STANDARD=Gemma 4 (local), LIGHT=GLM-4.7 Flash",
      "tiers": {
        "LIGHT": "mor-gateway/glm-4.7-flash",
        "STANDARD": "ollama/gemma4:e4b",
        "HEAVY": "mor-gateway/glm-5"
      }
    }
  },
  "tools": {
    "exec": {
      "_comment": "Set ask to 'off' to disable exec approval prompts. Use 'on-miss' for allowlist-based approval. Money operations are gated at the application layer (everclaw-wallet.mjs), not the exec layer.",
      "ask": "off",
      "strictInlineEval": false
    }
  },
  "agents": {
    "defaults": {
      "timeoutSeconds": 300,
      "model": {
        "_comment": "Primary: GLM-5 via Morpheus. Fallbacks: P2P → Local Ollama → Gateway (no centralized APIs).",
        "primary": "mor-gateway/glm-5",
        "fallbacks": [
          "morpheus/glm-5",
          "ollama/gemma4:e4b",
          "mor-gateway/glm-4.7-flash"
        ]
      },
      "models": {
        "mor-gateway/glm-5": {
          "streaming": true
        },
        "mor-gateway/glm-4.7-flash": {
          "streaming": true
        },
        "ollama/gemma4:e4b": {
          "streaming": true
        },
        "morpheus/glm-5": {
          "streaming": true
        },
        "morpheus/glm-4.7-flash": {
          "streaming": true
        }
      }
    }
  },
  "skills": {
    "defaults": {
      "securityTier": "recommended",
      "_comment": "Security tiers: low (permissive), recommended (balanced), maximum (restrictive)"
    }
  }
}